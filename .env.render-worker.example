# Dedicated Windows Jianying render worker. Copy to .env.render-worker on the
# render machine; never commit the real token or machine-specific paths.
WINDOWS_RENDER_API_TOKEN=replace-with-a-long-random-token
WINDOWS_RENDER_HOST=0.0.0.0
WINDOWS_RENDER_PORT=8765
WINDOWS_RENDER_PUBLIC_BASE_URL=http://RENDER-PC-LAN-IP:8765

# Use the exact paths configured in Jianying on the render machine.
WINDOWS_RENDER_DRAFT_ROOT=C:\Users\render\AppData\Local\JianyingPro\User Data\Projects\com.lveditor.draft
WINDOWS_RENDER_JIANYING_EXE=C:\Users\render\AppData\Local\JianyingPro\Apps\JianyingPro.exe
WINDOWS_RENDER_OUTPUT_DIR=C:\DouyinRenderWorker\output

# Native Windows UI Automation: opens the generated draft in Jianying and uses
# Jianying's own export dialog. It does not invoke FFmpeg.
WINDOWS_RENDER_EXPORT_DRIVER=uiautomation
# Optional escape hatch for a machine-specific driver. Only used when
# WINDOWS_RENDER_EXPORT_DRIVER=command.
WINDOWS_RENDER_EXPORT_COMMAND_JSON=

WINDOWS_RENDER_MIHE_TIMEOUT_SECONDS=60
WINDOWS_RENDER_DRAFT_TIMEOUT_SECONDS=900
WINDOWS_RENDER_EXPORT_TIMEOUT_SECONDS=1800
WINDOWS_RENDER_DRY_RUN=false
