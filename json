": \"call_1713008\", \"tool\": \"add_captions\", \"params\": {\"captions\": [{\"text\": \"《克林索尔的最后夏天》\\n\\n黑塞著\", \"start\": 4640000, \"end\": 6896000, \"font_size\": 17}], \"border_color\": \"#000000\", \"font\": \"思源粗宋\", \"font_size\": 18, \"letter_spacing\": 3, \"text_color\": \"#ffffff\", \"transform_y\": 1073}}, {\"call_id\": \"call_143757\", \"tool\": \"add_captions\", \"params\": {\"captions\": [{\"text\": \"那个夏天之后\", \"start\": 7396000, \"end\": 9028000, \"font_size\": 14}, {\"text\": \"我只在回忆里见过月亮\", \"start\": 9028000, \"end\": 11284000, \"font_size\": 14}, {\"text\": \"它高悬在克林索尔的梦境\", \"start\": 11284000, \"end\": 14116000, \"font_size\": 14}, {\"text\": \"洒下银白的光\", \"start\": 14116000, \"end\": 16156000, \"font_size\": 14}, {\"text\": \"照亮灵魂深处的渴望\", \"start\": 16156000, \"end\": 18820000, \"font_size\": 14}, {\"text\": \"我徘徊在时光的回廊\", \"start\": 18820000, \"end\": 21244000, \"font_size\": 14}, {\"text\": \"试图抓住那缕温热的风\", \"start\": 21244000, \"end\": 23908000, \"font_size\": 14}, {\"text\": \"它却像夏夜的流星\", \"start\": 23908000, \"end\": 26356000, \"font_size\": 14}, {\"text\": \"转瞬即逝，四季更迭\", \"start\": 26356000, \"end\": 29188000, \"font_size\": 14}, {\"text\": \"我在每个夏天寻觅\", \"start\": 29188000, \"end\": 31228000, \"font_size\": 14}, {\"text\": \"临摹那片璀璨\", \"start\": 31228000, \"end\": 33268000, \"font_size\": 14}, {\"text\": \"嫉妒它短暂\", \"start\": 33268000, \"end\": 34900000, \"font_size\": 14}, {\"text\": \"又痴迷它绚烂\", \"start\": 34900000, \"end\": 36772000, \"font_size\": 14}, {\"text\": \"冬天冰冷的雨\", \"start\": 36772000, \"end\": 38812000, \"font_size\": 14}, {\"text\": \"打湿了我对夏天的幻想，我知道\", \"start\": 38812000, \"end\": 41884000, \"font_size\": 14}, {\"text\": \"有些梦一旦醒来\", \"start\": 41884000, \"end\": 44164000, \"font_size\": 14}, {\"text\": \"就再难回去\", \"start\": 44164000, \"end\": 45628000, \"font_size\": 14}, {\"text\": \"但我依然相信\", \"start\": 45628000, \"end\": 47500000, \"font_size\": 14}, {\"text\": \"全世界的水终会重逢\", \"start\": 47500000, \"end\": 50548000, \"font_size\": 14}, {\"text\": \"在云端，在银河\", \"start\": 50548000, \"end\": 53212000, \"font_size\": 14}, {\"text\": \"在每一个灵魂的深处\", \"start\": 53212000, \"end\": 55636000, \"font_size\": 14}, {\"text\": \"那一场盛大的告别\", \"start\": 55636000, \"end\": 57916000, \"font_size\": 14}, {\"text\": \"是克林索尔的挽歌\", \"start\": 57916000, \"end\": 60196000, \"font_size\": 14}, {\"text\": \"也是我心中永恒的诗\", \"start\": 60196000, \"end\": 63244000, \"font_size\": 14}, {\"text\": \"它让我懂得\", \"start\": 63244000, \"end\": 64876000, \"font_size\": 14}, {\"text\": \"即使美好终将逝去\", \"start\": 64876000, \"end\": 67540000, \"font_size\": 14}, {\"text\": \"却依然值得用一生去铭记\", \"start\": 67540000, \"end\": 70612000, \"font_size\": 14}], \"alignment\": 1, \"border_color\": \"#000000\", \"font\": \"华文行楷\", \"font_size\": 9, \"line_spacing\": -3, \"text_color\": \"#dfd5d5\", \"transform_x\": -35, \"transform_y\": -810}}, {\"call_id\": \"call_138594\", \"tool\": \"add_captions\", \"params\": {\"captions\": [{\"text\": \" \", \"start\": 0, \"end\": 70612000, \"font_size\": 8}], \"alpha\": 0.6, \"font\": \"高字标志黑\", \"font_size\": 8, \"letter_spacing\": 2, \"text_color\": \"#ffffff\", \"transform_y\": 800}}]}"