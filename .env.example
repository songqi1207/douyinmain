# Browser-facing URL that Coze/Mihe can use to fetch uploaded assets.
PUBLIC_BASE_URL=https://your-domain.example.com

# Stage 1: template = topic -> downloadable Coze workflow JSON.
# After every workflow is tested and published, switch to published + coze.
WORKFLOW_BUILD_MODE=template
WORKFLOW_PROVIDER_MODE=demo
WORKFLOW_QUEUE_MODE=inline

COZE_API_TOKEN=
COZE_WORKFLOW_G247=
COZE_WORKFLOW_G218=
COZE_WORKFLOW_G159=
COZE_WORKFLOW_G259=
COZE_WORKFLOW_G258=
COZE_WORKFLOW_G168=
COZE_WORKFLOW_G45=
COZE_WORKFLOW_G263=
COZE_WORKFLOW_G129=
COZE_WORKFLOW_G222=
COZE_WORKFLOW_OWN03=
# Backward-compatible alias for COZE_WORKFLOW_OWN03.
COZE_WORKFLOW_GOD=
MIHE_KEY=
SUTUI_API_KEY=
VOLCENGINE_API_KEY=
FEISHU_ASSET_URL=
WORKFLOW_RENDER_API_URL=
WORKFLOW_RENDER_API_TOKEN=
WORKFLOW_RENDER_TIMEOUT_SECONDS=2400
WORKFLOW_RENDER_DOWNLOAD_TIMEOUT_SECONDS=1800
WORKFLOW_RENDER_MAX_VIDEO_BYTES=4294967296
WORKFLOW_MAX_DRAFT_KEY_BYTES=5242880

# Volcengine VOD server-side editing. Keep the real AK/SK in .env only.
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=
VOD_SPACE_NAME=douyin-render-dev
VOD_REGION=cn-north-1

# Optional internal accounting fields (never shown as provider secrets).
WORKFLOW_COST_CENTS_G247=100
WORKFLOW_PRICE_CENTS_G247=150

# Production Docker Compose uses these automatically.
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=*

# Windows 本地生成剪映草稿时必须指向剪映“全局设置 → 草稿位置”显示的目录。
# 未配置且检测不到默认目录时，程序只会写到项目的 temp/jianying_drafts 兜底目录。
JIANYING_DRAFT_ROOT=

# Member accounts use an HttpOnly same-site session cookie. Enable secure cookies on HTTPS production.
SITE_COOKIE_SECURE=false
SITE_SESSION_TTL_SECONDS=2592000
# Optional separate SQLite file; defaults to WORKFLOW_DATA_DIR/site.sqlite3.
SITE_DB_PATH=

# Approval-only registration. These credentials bootstrap the admin reviewer account.
# Use a long unique password in .env; never commit the real value.
SITE_ADMIN_EMAIL=admin@example.com
SITE_ADMIN_PASSWORD=replace-with-a-long-random-password

# Real approval email delivery. Approve is blocked when SMTP_HOST/SMTP_FROM are absent.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false

# Optional cloud TTS adapter. Expected response: {audio_url}, {url}, or {data: {link, duration}}.
# Without TTS_API_URL the server lists and uses only actually installed Windows System.Speech voices.
# With a cloud adapter, provide its real public voice catalog as a JSON array; no fictional fallback voices are shown.
TTS_API_URL=
TTS_API_TOKEN=
TTS_VOICES_JSON=[]
